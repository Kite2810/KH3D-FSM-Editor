<Window x:Class="FsmTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:FsmTool"
        Title="KH3D FSM Editor" Height="820" Width="1180"
        MinWidth="900" MinHeight="560"
        WindowStyle="None" AllowsTransparency="False"
        Background="{StaticResource Bg}"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        SnapsToDevicePixels="True" UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" CornerRadius="0" GlassFrameThickness="0"
                            ResizeBorderThickness="5" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <!-- title bar -->
            <RowDefinition Height="48"/>
            <!-- command bar -->
            <RowDefinition Height="*"/>
            <!-- content -->
            <RowDefinition Height="30"/>
            <!-- status -->
        </Grid.RowDefinitions>

        <!-- ══ TITLE BAR ════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource TitleBar}"
                BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Border Width="16" Height="16" CornerRadius="3"
                            Background="{StaticResource AccentSubtle}" Margin="0,0,9,0">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                   Foreground="{StaticResource Accent}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="KH3D FSM Editor" FontSize="13" FontWeight="SemiBold"
                               Foreground="#FFD0D0D0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleFile" FontSize="12" Foreground="{StaticResource Muted}"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource CaptionBtn}" Click="MinimizeBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </Button>
                    <Button Style="{StaticResource CaptionBtn}" Click="MaximizeBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock x:Name="MaxIcon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </Button>
                    <Button Style="{StaticResource CloseBtn}" Click="CloseBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ COMMAND BAR ══════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource CommandBar}"
                BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <Button Content="Open .fsm" Click="Open_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Border Width="1" Background="{StaticResource Stroke}" Margin="8,8"/>
                <Button x:Name="BtnRevert" Content="Revert" Click="Revert_Click" IsEnabled="False"
                        Margin="0,0,6,0" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button x:Name="BtnSaveAs" Content="Save As copy…" Click="SaveAs_Click" IsEnabled="False"
                        Margin="0,0,6,0" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button x:Name="BtnRedirect" Content="Redirect all → Idle" Click="RedirectAll_Click" IsEnabled="False"
                        Margin="0,0,6,0" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button x:Name="BtnReport" Content="Save report" Click="SaveReport_Click" IsEnabled="False"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </StackPanel>
        </Border>

        <!-- ══ CONTENT ══════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <!-- empty state -->
            <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="56" Height="56" CornerRadius="12" Background="{StaticResource Card}"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                               Foreground="{StaticResource Muted}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="No FSM file loaded" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                <TextBlock Text="Drop a .fsm here, or use Open .fsm" FontSize="12"
                           Foreground="{StaticResource Muted}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <Grid x:Name="MainContent" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="460"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="380" MinWidth="320"/>
                </Grid.ColumnDefinitions>

                <!-- ── LEFT: transitions list ─────────────────────────── -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FF1C1C1C"
                            BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1">
                        <Grid Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TRANSITIONS" Style="{StaticResource SectionLabel}"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="#14FFFFFF" CornerRadius="8" Padding="7,2"
                                    VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock x:Name="CountBadge" FontSize="10"
                                           FontFamily="Consolas" Foreground="{StaticResource TextSecondary}"/>
                            </Border>
                            <TextBox Grid.Column="2" x:Name="SearchBox" Style="{StaticResource ModernInput}"
                                     Height="28" FontSize="12" VerticalContentAlignment="Center"
                                     TextChanged="SearchBox_TextChanged" Margin="0,0,10,0"/>
                            <Button Grid.Column="3" x:Name="FilterAllBtn" Content="All"
                                    Style="{StaticResource FilterOn}" Click="FilterAll_Click"/>
                            <Button Grid.Column="5" x:Name="FilterAtkBtn" Content="Attack"
                                    Style="{StaticResource FilterOff}" Click="FilterAttack_Click"/>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1" x:Name="Grid" SelectionChanged="Grid_SelectionChanged"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STATE" Binding="{Binding Owner}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="→ TARGET" Binding="{Binding Target}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="WHEN" Binding="{Binding When}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="FontSize" Value="11"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="" Width="58">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource AttackSubtle}"
                                                BorderBrush="{StaticResource Attack}" BorderThickness="1"
                                                CornerRadius="3" Padding="5,1" HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsAttack, Converter={x:Static local:BoolVis.Instance}}">
                                            <TextBlock Text="ATK" FontWeight="Bold" FontSize="9"
                                                       Foreground="{StaticResource Attack}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- divider -->
                <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Stretch"
                              Background="{StaticResource Stroke}" Cursor="SizeWE"/>

                <!-- ── RIGHT: details ─────────────────────────────────── -->
                <Border Grid.Column="2" Background="#FF1C1C1C">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource Panel}"
                                BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1">
                            <TextBlock Text="DETAILS" Style="{StaticResource SectionLabel}"
                                       Margin="14,0,0,0" VerticalAlignment="Center"/>
                        </Border>

                        <!-- no selection: file info -->
                        <ScrollViewer Grid.Row="1" x:Name="NoSelPanel" VerticalScrollBarVisibility="Auto"
                                      Padding="12">
                            <StackPanel>
                                <Border Background="{StaticResource Card}" CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="FILE" Style="{StaticResource SectionLabel}"/>
                                        <TextBlock x:Name="InfoName" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="InfoMeta" Style="{StaticResource Mono}" FontSize="11" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{StaticResource Card}" CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="SUMMARY" Style="{StaticResource SectionLabel}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock x:Name="InfoStates" FontSize="20" FontWeight="Bold"
                                                           Foreground="{StaticResource Text}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="States" FontSize="10" Foreground="{StaticResource Muted}"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock x:Name="InfoTrans" FontSize="20" FontWeight="Bold"
                                                           Foreground="{StaticResource Accent}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Edges" FontSize="10" Foreground="{StaticResource Muted}"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                <TextBlock x:Name="InfoAttacks" FontSize="20" FontWeight="Bold"
                                                           Foreground="{StaticResource Attack}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Attacks" FontSize="10" Foreground="{StaticResource Muted}"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="← Select a transition to edit its target and conditions"
                                           FontSize="11" Foreground="{StaticResource Muted}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- selection: transition editor -->
                        <ScrollViewer Grid.Row="1" x:Name="SelPanel" VerticalScrollBarVisibility="Auto"
                                      Padding="12" Visibility="Collapsed">
                            <StackPanel>
                                <!-- transition -->
                                <Border Background="{StaticResource Card}" CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="TRANSITION" Style="{StaticResource SectionLabel}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding Owner}" FontSize="14" FontWeight="Bold"
                                                       FontFamily="Consolas" Foreground="{StaticResource TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="  →" FontSize="14" Foreground="{StaticResource Muted}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Target state" FontSize="10" Foreground="{StaticResource Muted}"
                                                   Margin="0,0,0,3"/>
                                        <ComboBox x:Name="TargetCombo"
                                                  ItemsSource="{Binding DataContext.StateOptions,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding Target, Mode=OneWay}"
                                                  SelectionChanged="Target_Changed"/>
                                    </StackPanel>
                                </Border>

                                <!-- conditions -->
                                <Border Background="{StaticResource Card}" CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="CONDITIONS" Style="{StaticResource SectionLabel}" Margin="0,0,8,6"/>
                                            <Border Background="#14FFFFFF" CornerRadius="8" Padding="7,1"
                                                    Height="16" VerticalAlignment="Top">
                                                <TextBlock FontSize="10" FontFamily="Consolas"
                                                           Foreground="{StaticResource TextSecondary}">
                                                    <Run Text="{Binding Conditions.Count, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding Conditions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF1F1F1F" CornerRadius="5" Padding="9,7" Margin="0,0,0,5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ComboBox Grid.Column="0"
                                                                      ItemsSource="{Binding DataContext.ConditionOptions,
                                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      SelectedItem="{Binding Name, Mode=OneWay}"
                                                                      SelectionChanged="CondName_Changed"
                                                                      Margin="0,0,8,0"/>
                                                            <ComboBox Grid.Column="1"
                                                                      ItemsSource="{Binding DataContext.OperatorOptions,
                                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      SelectedItem="{Binding OpText, Mode=OneWay}"
                                                                      SelectionChanged="CondOp_Changed"
                                                                      Width="62" Margin="0,0,8,0"/>
                                                            <CheckBox Grid.Column="2" x:Name="chk" VerticalAlignment="Center"
                                                                      IsChecked="{Binding BoolValue, Mode=OneWay}"
                                                                      Visibility="Collapsed" Click="CondBool_Click"/>
                                                            <TextBox Grid.Column="2" x:Name="num"
                                                                     Style="{StaticResource ModernInput}"
                                                                     Width="92" Height="24" FontSize="12"
                                                                     VerticalContentAlignment="Center" TextAlignment="Center"
                                                                     Text="{Binding ValueText, Mode=OneWay}"
                                                                     KeyDown="CondNum_KeyDown" LostFocus="CondNum_LostFocus"/>
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsBool}" Value="True">
                                                            <Setter TargetName="chk" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="num" Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock x:Name="NoCondText" Text="Fires unconditionally (no conditions)."
                                                   FontSize="11" FontStyle="Italic" Foreground="{StaticResource Muted}"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                </Border>

                                <!-- actions -->
                                <Border Background="{StaticResource Card}" CornerRadius="8" Padding="14,12">
                                    <StackPanel>
                                        <TextBlock Text="ACTIONS" Style="{StaticResource SectionLabel}"/>
                                        <Button Content="Redirect this transition → Idle"
                                                HorizontalContentAlignment="Left" Padding="11,7"
                                                Click="RedirectOne_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ══ STATUS BAR ════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#FF161616"
                BorderBrush="{StaticResource Stroke}" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <TextBlock x:Name="Status" Text="Drag a .fsm onto this window, or use Open .fsm."
                           FontSize="11" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="EditedBadge" Background="#1AFFAA40" CornerRadius="3"
                            BorderBrush="#33FFAA40" BorderThickness="1" Padding="7,1" Margin="0,0,8,0"
                            Visibility="Collapsed">
                        <TextBlock Text="● edited" FontSize="10" FontWeight="SemiBold" Foreground="#FFFFAA40"/>
                    </Border>
                    <TextBlock x:Name="StatusRight" FontSize="10" Foreground="{StaticResource Muted}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
